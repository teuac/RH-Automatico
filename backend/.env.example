# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rh_presenca

# Security & JWT
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=supersecretkeychangeinproduction1234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth Setup (Workspace Login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_DOMAIN=acengenharia.com.br

# Google Sheets Service Account Integration
# Opção 1 (recomendado): defina as variáveis individualmente
GOOGLE_SA_PROJECT_ID=your-project-id
GOOGLE_SA_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_SA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n
GOOGLE_SA_CLIENT_EMAIL=your-sa-name@your-project-id.iam.gserviceaccount.com
GOOGLE_SA_CLIENT_ID=123456789012345678901
GOOGLE_SA_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-sa-name%40your-project-id.iam.gserviceaccount.com

# Opção 2: cole o JSON completo da Service Account aqui (menos seguro)
# GOOGLE_SERVICE_ACCOUNT_INFO={"type":"service_account",...}

# Opção 3: caminho para arquivo JSON local
# GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json
