# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rh_presenca

# Security & JWT
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=supersecretkeychangeinproduction1234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth Setup (Workspace Login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_DOMAIN=acengenharia.com.br

# Google Sheets Service Account Integration
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json
